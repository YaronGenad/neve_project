# ── Al-Hasade Production Environment Template ─────────────────────────────────
# Copy this file to .env.prod and fill in ALL values before deploying.
# Never commit .env.prod with real secrets.
#
# Usage:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_RANDOM_256_BIT_HEX

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (Aurora Serverless) ──────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@AURORA_ENDPOINT:5432/DBNAME
# Connection pooling: min=2, max=10 (Aurora cold-start requires small pool)
AURORA_CONNECTION_STRING=postgresql://alhasade:REPLACE_PASSWORD@AURORA_CLUSTER_ENDPOINT:5432/alhasade

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
NVIDIA_API_KEY=

# ── File Storage ──────────────────────────────────────────────────────────────
OUTPUT_DIR=/app/output
MAX_FILE_AGE_HOURS=24

# ── Search ────────────────────────────────────────────────────────────────────
# Calibrate after 200+ teacher queries; start with 0.3
VECTOR_SIMILARITY_THRESHOLD=0.3

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# Grafana admin password — used in docker-compose.monitoring.yml
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
